# TechFin — Environment Configuration
# Copy to .env and adjust for your environment.
# For Databricks Apps, set these in app.yaml.
# For Databricks Jobs/Notebooks, use spark.conf or dbutils.widgets.

# Databricks Workspace
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_PROFILE=DEFAULT

# Unity Catalog (tables, model, volume are auto-derived)
UC_CATALOG=your_catalog
UC_SCHEMA=your_schema

# Serving Endpoint
OCR_ENDPOINT=techfin-ocr-v4
OCR_MODEL=databricks-claude-sonnet-4-6

# Secrets
SECRET_SCOPE=your-scope
SECRET_KEY=techfin-ocr-pat

# MLflow
MLFLOW_EXPERIMENT_ID=your_experiment_id

# Jobs
FEWSHOT_JOB_ID=your_job_id

# Warehouses
WAREHOUSE_ID=your_warehouse_id
SERVERLESS_WAREHOUSE_ID=your_serverless_warehouse_id
